# TuParles release env — copy to `.env` (gitignored, mode 600) and fill in.
# See docs / SRE runbook play-store-release.md for how each value is obtained.

# Play Developer API service-account JSON key — a PATH, not a secret.
GOOGLE_PLAY_SA_KEY_PATH=/absolute/path/to/service-account.json
# Play application id (Console package name).
PLAY_PACKAGE_NAME=pl.nech.tuparles

# Release signing — read into the Gradle process env by app/build.gradle.kts.
# The store password doubles as the key password (single-password keystore).
TUPARLES_UPLOAD_KEYSTORE=/absolute/path/to/tuparles-upload.jks
TUPARLES_UPLOAD_KEY_ALIAS=tuparles-upload
TUPARLES_UPLOAD_KEYSTORE_PASS=your-keystore-password
