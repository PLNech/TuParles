<?xml version="1.0" encoding="utf-8"?>
<!-- DEBUG-ONLY overlay. INTERNET lives here, never in the main manifest, so the
     release flavor keeps TuParles' defining property: no socket, denied by the OS,
     structural privacy by construction. The debug build carries INTERNET solely to
     sync the durable telemetry outbox to domovoy (see DomovoySync) while developing
     and during the trip. Manifest merger adds these to debug builds only. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>
