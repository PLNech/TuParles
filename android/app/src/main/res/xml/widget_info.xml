<?xml version="1.0" encoding="utf-8"?>
<!-- No periodic update (updatePeriodMillis=0): the widget is event-driven, refreshed
     by DictationService while a take is in flight, not on a timer. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_tuparles"
    android:previewLayout="@layout/widget_tuparles"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
