<?xml version="1.0" encoding="utf-8"?>
<!-- Privacy invariant (the real moat is our outlook, not our permission set): voice,
     recordings, and any user data NEVER leave this device. The one thing that crosses
     the network is INBOUND ONLY — downloading a speech model from huggingface.co so the
     lean APK need not bundle hundreds of MB (#13). Nothing about the user is ever
     uploaded: mic audio, transcripts, and notes stay on-device; sharing a note is still
     the user's own explicit share-sheet action to an app they choose. RECORD_AUDIO
     remains the only sensitive permission. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Hold the mic correctly while recording: a foreground service of type
         microphone (Android 14+ requirement) + its notification. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Inbound only: fetch a whisper model from huggingface.co via the system
         DownloadManager. No user data is ever sent out — see the invariant above. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read-only network state: check whether the active network is metered before
         the direct-HTTP download fallback runs, so allowMetered=false is honoured even
         when the system DownloadManager stalls (Android 15 scheduler deferral, #13). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".TuParlesApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TuParles">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TuParles">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Compute backbone: owns recording off the UI lifecycle (a take survives
             screen-off / app-switch), foreground type=microphone while active. -->
        <service
            android:name=".record.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Shares a note's WAV to another app via a content:// URI. We never send it
             ourselves — the receiving app does any sending, the user drives it. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="pl.nech.tuparles.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
