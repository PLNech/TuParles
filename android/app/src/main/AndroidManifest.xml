<?xml version="1.0" encoding="utf-8"?>
<!-- Structural privacy: no INTERNET permission is declared, by design. The whole
     point is local-only STT — the OS itself denies any socket the app might try.
     RECORD_AUDIO is the only sensitive permission; the audio never leaves the box. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Hold the mic correctly while dictating: a foreground service of type
         microphone (Android 14+ requirement) + its notification. No INTERNET here. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TuParlesApp"
        android:allowBackup="false"
        android:label="TuParles"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar">
        <!-- Home: the dictation scratchpad. -->
        <activity
            android:name=".ScratchpadActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|density|fontScale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The de-risk / capture harness, now reached from the scratchpad. -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|density|fontScale" />

        <!-- The learning store, made visible: per-take 👍/👎/✏️ labelling. -->
        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|density|fontScale" />

        <!-- Full settings (perf/threads, models, privacy) — the "it's a setting" home. -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|density|fontScale" />

        <!-- Compute backbone: owns recording + decode off the UI lifecycle (fixes the
             lost-take bug), foreground type=microphone while active. -->
        <service
            android:name=".DictationService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- The TuParles speech keyboard (InputMethodService): what makes the STT
             app-agnostic — commits postprocessed text into any app's focused field. -->
        <service
            android:name=".TuParlesIme"
            android:label="TuParles"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Smart home-screen widget: one-tap dictate → clipboard + notification,
             live state pushed by DictationService. -->
        <receiver
            android:name=".TuParlesWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="pl.nech.tuparles.WIDGET_TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Shares capture files to an email app via content:// URIs. No INTERNET
             permission for us — the email app does the sending, off-device control
             stays with the user. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="pl.nech.tuparles.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
